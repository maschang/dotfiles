{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker container exec * bash -c *bundle exec*)",
      "Bash(docker container exec * bash -c *rails *)",
      "Bash(docker container exec * bash -c *rspec*)",
      "Bash(docker exec * bash -c *bundle exec*)",
      "Bash(docker exec * bash -c *rails *)",
      "Bash(docker exec * bash -c *rspec*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**/secrets/**)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "language": "日本語",
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  }
}
